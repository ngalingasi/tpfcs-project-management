meta {
  name: OTP Step 1 - Validate Credentials
  type: http
  seq: 8
}

post {
  url: {{base_url}}/auth/validate-credentials
  body: json
  auth: none
}

body:json {
  {
    "login": "admin",
    "password": "password"
  }
}

script:post-response {
  const data = res.getBody();
  if (data && data.status) {
    console.log("✅ Credentials valid");
    console.log("Available channels:", JSON.stringify(data.channels));
  } else {
    console.log("❌ Failed:", data.message);
  }
}
