meta {
  name: Create Target
  type: http
  seq: 1
}

post {
  url: {{base_url}}/objectives/1/targets
  body: json
  auth: bearer
}
auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "objective_id": 1,
    "name": "Number of boreholes constructed",
    "metric_type": "count",
    "unit": "boreholes",
    "target_value": 50,
    "deadline": "2025-12-31",
    "status": "on_track"
  }
}
